# Enterprise GitLab CI/CD for Marcus Fleet Antigravity Engine
# V30.2: Validates specs, development ledgers, doc sync, delta RAG, and sandbox checks.

stages:
  - validate
  - analyze
  - sandboxed-execute

image: python:3.10-slim

variables:
  PIP_CACHE_DIR: "$CI_PROJECT_DIR/.cache/pip"

cache:
  paths:
    - .cache/pip
    - .agents/venv/

before_script:
  - python -V
  - pip install virtualenv
  - virtualenv .agents/venv
  - source .agents/venv/bin/activate
  - pip install -r .agents/requirements.txt

spec-governance-validation:
  stage: validate
  script:
    - python .agents/scripts/validate_specs.py
    - |
      if [ -d docs/research ]; then
        python .agents/scripts/validate_planning_research.py --root .
      else
        echo "No docs/research directory found; skipping planning research validation."
      fi
    - |
      if [ -d docs/development ]; then
        python .agents/scripts/validate_development_docs.py --strict-counts
        python .agents/scripts/validate_doc_sync.py --base-ref HEAD~1 --strict
      else
        echo "No docs/development directory found; skipping development docs validation."
      fi
  only:
    - merge_requests
    - main

cognitive-delta-sync:
  stage: analyze
  script:
    - echo "Calculating Delta context bounds..."
    - apt-get update && apt-get install -y git
    - git diff --name-only HEAD~1 HEAD > .agents/changed_files.txt
    - |
      if [ -s .agents/changed_files.txt ]; then
        python .agents/adapters/trustgraph_incremental.py --files $(cat .agents/changed_files.txt)
      else
        echo "No changed files detected; skipping TrustGraph incremental sync."
      fi
  only:
    - merge_requests
    - main

agent-safety-check:
  stage: sandboxed-execute
  script:
    - chmod +x .agents/run_sandboxed.sh
    - .agents/run_sandboxed.sh "npm config list"
    - python .agents/adapters/telemetry_export.py --agent_id "gitlab_runner" --action "Execution_Pass"
  only:
    - merge_requests
