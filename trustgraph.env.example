# TrustGraph local development defaults.
# Copy to .agents/trustgraph.env or export these variables in CI.

NEO4J_USER=neo4j
NEO4J_PASSWORD=trustgraph_secret
NEO4J_URI=bolt://localhost:7687
TRUSTGRAPH_NEO4J_HTTP_ENDPOINT=http://localhost:7474/db/neo4j/tx/commit

POSTGRES_USER=trustgraph
POSTGRES_PASSWORD=trustgraph_secret
POSTGRES_DB=trustgraph_memory

CHROMA_HOST=localhost
CHROMA_PORT=8800
CHROMA_COLLECTION=codebase
